[Unit]
Description=Codex CLI over Telegram
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=gnu
Group=gnu
WorkingDirectory=/home/gnu/codex-cli-over-telegram
Environment=HOME=/home/gnu
Environment=PATH=/home/gnu/.local/bin:/home/gnu/.grok/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
EnvironmentFile=/etc/codex-cli-over-telegram/env
EnvironmentFile=-/etc/codex-cli-over-telegram/deploy.env
ExecStart=/usr/bin/node /home/gnu/codex-cli-over-telegram/dist/index.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/gnu

[Install]
WantedBy=multi-user.target
